Sub Extract15DigitFromKtoU()

    Dim lastRow As Long
    Dim i As Long
    Dim cellText As String
    Dim regex As Object
    Dim matches As Object

    ' Create the RegExp object
    Set regex = CreateObject("VBScript.RegExp")
    regex.Global = False
    regex.Pattern = "\b\d{15}\b" ' looks for exactly 15-digit numbers
    regex.IgnoreCase = True

    ' Find the last used row in column K
    lastRow = Cells(Rows.Count, "K").End(xlUp).Row

    ' Loop through each row
    For i = 1 To lastRow
        cellText = Trim(Cells(i, "K").Value)
        
        If regex.Test(cellText) Then
            Set matches = regex.Execute(cellText)
            Cells(i, "U").Value = matches(0).Value
        End If
    Next i

    ' Set column U width to 25
    Columns("U:U").ColumnWidth = 25
    
    ' Set column U format to Text
    Columns("U:U").NumberFormat = "@"

End Sub
