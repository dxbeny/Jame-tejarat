Sub HighlightMatchingInvoices()
    Dim wbA As Workbook, wbB As Workbook
    Dim wsA As Worksheet, wsB As Worksheet
    Dim lastRowA As Long, lastRowB As Long
    Dim i As Long, j As Long
    Dim valA As String, valB As String
    Dim matchCount As Long
    Dim pathA As Variant, pathB As Variant

    ' ===== انتخاب فایل A =====
    MsgBox "لطفاً فایل اول (A) رو انتخاب کنید", vbInformation
    pathA = Application.GetOpenFilename("Excel Files (*.xlsx; *.xlsm; *.xls), *.xlsx; *.xlsm; *.xls", , "انتخاب فایل A")
    If pathA = False Then Exit Sub
    Set wbA = Workbooks.Open(pathA)

    ' ===== انتخاب فایل B =====
    MsgBox "حالا فایل دوم (B) رو انتخاب کنید", vbInformation
    pathB = Application.GetOpenFilename("Excel Files (*.xlsx; *.xlsm; *.xls), *.xlsx; *.xlsm; *.xls", , "انتخاب فایل B")
    If pathB = False Then Exit Sub
    Set wbB = Workbooks.Open(pathB)

    ' ===== شیت‌ها: پیش‌فرض شیت اول هر فایل =====
    Set wsA = wbA.Sheets(1)
    Set wsB = wbB.Sheets(1)

    lastRowA = wsA.Cells(wsA.Rows.Count, "B").End(xlUp).Row
    lastRowB = wsB.Cells(wsB.Rows.Count, "B").End(xlUp).Row

    matchCount = 0

    For i = 1 To lastRowA
        valA = Trim(wsA.Cells(i, "B").Value)
        If valA <> "" Then
            For j = 1 To lastRowB
                valB = Trim(wsB.Cells(j, "B").Value)
                If valB <> "" And valA = valB Then
                    wsA.Cells(i, "B").Font.Color = RGB(255, 0, 0)
                    wsB.Cells(j, "B").Font.Color = RGB(255, 0, 0)
                    matchCount = matchCount + 1
                End If
            Next j
        End If
    Next i

    MsgBox matchCount & " صورتحساب مشترک پیدا و قرمز شد.", vbInformation
End Sub
